<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>
<AnchorPane prefHeight="344.0" prefWidth="423.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17"
            fx:controller="cn.net.pap.example.javafx.LoginController">
    <children>
        <Label layoutX="40" layoutY="60" prefHeight="33.0" prefWidth="125.0" text="用户名："/>
        <TextField fx:id="usernameField" layoutX="200.0" layoutY="65.0" prefWidth="150"/>
        <PasswordField fx:id="passwordField" layoutX="200.0" layoutY="161.0" prefWidth="150"/>
        <Label layoutX="40.0" layoutY="156.0" prefHeight="33.0" prefWidth="125.0" text="密码"/>
        <Button layoutX="180.0" layoutY="255.0" onAction="#onLoginButtonClick" text="登录"/>
    </children>
</AnchorPane>
