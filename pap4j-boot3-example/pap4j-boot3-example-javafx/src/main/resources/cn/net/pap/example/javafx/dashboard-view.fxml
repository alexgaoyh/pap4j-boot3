<VBox prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cn.net.pap.example.javafx.DashboardController">
    <children>
        <MenuBar VBox.vgrow="NEVER">
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Open Folder..." onAction="#handleOpenFolder" />
                        <!--<MenuItem mnemonicParsing="false" text="New" />
                        <MenuItem mnemonicParsing="false" text="Open…" />
                        <Menu mnemonicParsing="false" text="Open Recent" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem mnemonicParsing="false" text="Close" />
                        <MenuItem mnemonicParsing="false" text="Save" />
                        <MenuItem mnemonicParsing="false" text="Save As…" />
                        <MenuItem mnemonicParsing="false" text="Revert" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem mnemonicParsing="false" text="Preferences…" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem mnemonicParsing="false" text="Quit" />-->
                    </items>
                </Menu>
<!--                <Menu mnemonicParsing="false" text="Edit">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Undo" />
                        <MenuItem mnemonicParsing="false" text="Redo" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem mnemonicParsing="false" text="Cut" />
                        <MenuItem mnemonicParsing="false" text="Copy" />
                        <MenuItem mnemonicParsing="false" text="Paste" />
                        <MenuItem mnemonicParsing="false" text="Delete" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem mnemonicParsing="false" text="Select All" />
                        <MenuItem mnemonicParsing="false" text="Unselect All" />
                    </items>
                </Menu>-->
                <Menu mnemonicParsing="false" text="Help">
                    <items>
<!--                        <MenuItem mnemonicParsing="false" text="About MyHelloApp" />-->
                        <MenuItem mnemonicParsing="false" text="Refresh" onAction="#onHandleRefresh">
                            <accelerator>
                                <KeyCodeCombination alt="UP" control="UP" meta="UP" shift="UP" shortcut="UP" code="F5" />
                            </accelerator>
                        </MenuItem>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
        <SplitPane dividerPositions="0.2505567928730512, 0.7505567928730512" focusTraversable="true" prefHeight="-1.0" prefWidth="-1.0" VBox.vgrow="ALWAYS">
            <items>
                <VBox>
                    <TreeView fx:id="folderTreeView" VBox.vgrow="ALWAYS">
                    </TreeView>
                </VBox>
                <BorderPane>
                    <center>
                        <StackPane minWidth="0" minHeight="0" fx:id="stackPane">
                            <!--<Canvas fx:id="gridOverlay" pickOnBounds="false"></Canvas>-->
                            <ZoomableImageView fx:id="zoomableView"/>
                        </StackPane>
                    </center>
                    <bottom>
                        <HBox alignment="CENTER" spacing="10" prefHeight="40" maxHeight="40" style="-fx-background-color: #f0f0f0; -fx-padding: 10;">
                            <Button text="上一张" prefWidth="80" onAction="#handlePreviousImage"/>
                            <Button text="1:1" prefWidth="80" onAction="#sizeView"/>
                            <Button text="重置" prefWidth="80" onAction="#resetView"/>
                            <Button text="下一张" prefWidth="80" onAction="#handleNextImage"/>
                            <Label fx:id="scaleLabel" text="100%"/>
                        </HBox>
                    </bottom>
                </BorderPane>
                <AnchorPane>
                    <children>
                        <SplitPane dividerPositions="0.5" orientation="VERTICAL" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                            <items>
                                <AnchorPane>
                                    <children>
                                        <Button text="去除图像内" onAction="#imageRemoveIn" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"/>
                                    </children>
                                </AnchorPane>

                                <AnchorPane>
                                    <children>
                                        <Button text="目录刷新" onAction="#handleRefreshSelectedNode" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"/>
                                    </children>
                                </AnchorPane>
                            </items>
                        </SplitPane>
                    </children>
                </AnchorPane>
            </items>
        </SplitPane>
        <HBox id="HBox" alignment="CENTER_LEFT" spacing="5.0" VBox.vgrow="NEVER">
            <children>
                <Label maxHeight="1.7976931348623157E308" maxWidth="-1.0" text="Left status" HBox.hgrow="ALWAYS" style="-fx-font-size: 12px;" >
                    <font>
                        <Font size="11.0" fx:id="x3" />
                    </font>
                    <textFill>
                        <Color red="0.625" green="0.625" blue="0.625" fx:id="x4" />
                    </textFill>
                </Label>
                <Pane prefHeight="-1.0" prefWidth="-1.0" HBox.hgrow="ALWAYS" />
                <Label font="$x3" maxWidth="-1.0" text="Right status" textFill="$x4" HBox.hgrow="NEVER" style="-fx-font-size: 12px;" />
            </children>
            <padding>
                <Insets bottom="3.0" left="3.0" right="3.0" top="3.0" />
            </padding>
        </HBox>
    </children>
</VBox>
